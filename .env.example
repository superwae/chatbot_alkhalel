# Municipality Chatbot - Production Environment Variables
# Copy this file to .env on your server and fill in the values

# ===================
# REQUIRED - Must Set
# ===================

# Database password
POSTGRES_PASSWORD=your_secure_password_here

# JWT signing key (use a long random string, at least 32 characters)
AUTH__JWT__SIGNING_KEY=your_very_long_random_secret_key_here_at_least_32_chars

# Admin account password (created on first startup)
SEED__ADMIN__PASSWORD=YourSecureAdminPassword123!

# LLM Provider: OpenAI or Gemini
LLM__PROVIDER=OpenAI

# OpenAI API Key (required if using OpenAI)
OPENAI__API_KEY=sk-your-openai-key-here

# OR Gemini API Key (required if using Gemini)
# GEMINI__API_KEY=your-gemini-key-here

# ===================
# CORS - IMPORTANT for production
# ===================
# Set these to your actual domain/IP
CORS__ALLOWED_ORIGINS=http://192.168.100.25,http://your-domain.com
CORS__WIDGET_ALLOWED_ORIGINS=http://192.168.100.25,http://your-domain.com

# ===================
# OPTIONAL
# ===================

# Admin username (default: admin)
# SEED__ADMIN__USERNAME=admin

# Widget API key (optional security for embedded widget)
# WIDGET__API_KEY=optional-widget-key

# Rate limiting
# RATELIMIT__PUBLIC_CHAT__PERMIT_LIMIT=30
# RATELIMIT__PUBLIC_CHAT__WINDOW_SECONDS=60
